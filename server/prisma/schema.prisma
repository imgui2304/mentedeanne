generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  login String
  password String
}

model Document {
    id            String  @id @default(uuid())
    type String
    formData      Json
    resumo        String?
    palavrasChave Json
    referencias   Json?
    capitulos     Json?  // Permite valores nulos
}


